index 93f659f..dd943e6 100644
--- a/rate_eval/common.py
+++ b/rate_eval/common.py
@@ -159,24 +159,47 @@ def log_colored(logger: logging.Logger, level: str, message: str, color: str = N
 # =============================================================================
 
 
+def _mps_is_available() -> bool:
+    return hasattr(torch.backends, "mps") and torch.backends.mps.is_available()
+
+
+def get_default_device() -> torch.device:
+    if torch.cuda.is_available():
+        return torch.device("cuda")
+    if _mps_is_available():
+        return torch.device("mps")
+    return torch.device("cpu")
+
+
 def setup_device(device_spec: Optional[str] = None) -> torch.device:
     """
     Set up and validate device for model/data operations.
 
     Args:
-        device_spec: Device specification ('cuda', 'cpu', 'cuda:0', etc.)
+        device_spec: Device specification ('auto', 'cuda', 'mps', 'metal', 'cpu', etc.)
 
     Returns:
         Torch device object
     """
-    if device_spec is None:
-        device_spec = "cuda" if torch.cuda.is_available() else "cpu"
+    if device_spec is None or str(device_spec).lower() in {"", "auto"}:
+        return get_default_device()
+
+    device_spec = str(device_spec)
+    if device_spec.lower().startswith("metal"):
+        device_spec = "mps" + device_spec[5:]
 
     device = torch.device(device_spec)
 
     if device.type == "cuda" and not torch.cuda.is_available():
         logger = get_logger(__name__)
-        logger.warning("CUDA requested but not available, falling back to CPU")
+        fallback = get_default_device()
+        if fallback.type == "cuda":
+            fallback = torch.device("cpu")
+        logger.warning("%s requested but not available, falling back to %s", device, fallback)
+        device = fallback
+    elif device.type == "mps" and not _mps_is_available():
+        logger = get_logger(__name__)
+        logger.warning("MPS/Metal requested but not available, falling back to CPU")
         device = torch.device("cpu")
 
     return device
